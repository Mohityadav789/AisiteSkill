      "deep research", "web research", "answer with sources",
      "fact check", "citations", "source links", "study", "compare",
      "perplexity", "research assistant", "research tool"
    ],
    "flags": ["isResearchTool"]
  },

  "functions": [
    "deepResearch",
    "quickFacts",
    "compareTopics",
    "credibilityScore",
    "trendResearch"
  ],

  "requires": {
    "actions": ["web:search", "web:fetch", "ai:generate"]
  }
}
